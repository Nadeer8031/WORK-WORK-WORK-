    /* ----- reset & base ----- */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      margin: 0;
      min-height: 100vh;
      background-color: #F6F3E8;
      background-image: radial-gradient(#DFDCD4 1px, transparent 1px);
      background-size: 22px 22px;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: #340D1A;
      display: flex;
      justify-content: center;
      padding: 80px 20px;
    }
    .page {
      width: 100%;
      max-width: 490px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ----- brand ----- */
    .brand { text-align: center; margin-bottom: 40px; }
    .brand-name {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 34px;
      font-weight: 700;
      margin: 0 0 6px 0;
      color: #340D1A;
    }
    .brand-tagline {
      margin: 0;
      font-size: 13px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #B5A391;
    }

    /* ----- card ----- */
    .login-card {
      width: 100%;
      background-color: #ffffff;
      border-radius: 16px;
      padding: 48px 44px;
      box-shadow: 0 20px 40px rgba(52, 13, 26, 0.06);
    }
    .login-form { display: flex; flex-direction: column; }

    .form-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 28px;
      font-weight: 700;
      margin: 0 0 10px 0;
      color: #340D1A;
    }
    .form-subtitle {
      margin: 0 0 32px 0;
      font-size: 15px;
      color: #6b6560;
    }

    /* ----- fields ----- */
    .field-group { margin-bottom: 22px; }
    .field-label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: #340D1A;
      margin-bottom: 10px;
    }
    .input-wrapper {
      position: relative;
      display: flex;
      align-items: center;
    }
    .field-icon {
      position: absolute;
      left: 0;
      display: flex;
      align-items: center;
      color: #B5A391;
      pointer-events: none;
    }
    .field-icon svg { width: 18px; height: 18px; }

    .custom-input {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 1px solid #DFDCD4;
      padding: 12px 8px 12px 32px;
      font-size: 15px;
      font-family: inherit;
      color: #340D1A;
      outline: none;
      transition: border-color 0.2s ease;
    }
    .custom-input::placeholder {
      color: #B5A391;
      opacity: 0.7;
    }
    .custom-input:focus { border-bottom-color: #340D1A; }

    .password-wrapper .custom-input { padding-right: 36px; }

    .toggle-password {
      position: absolute;
      right: 0;
      background: none;
      border: none;
      cursor: pointer;
      color: #B5A391;
      display: flex;
      align-items: center;
      padding: 4px;
    }
    .toggle-password svg { width: 18px; height: 18px; }
    .toggle-password:hover { color: #340D1A; }

    .errors {
      min-height: 16px;
      font-size: 12px;
      color: #b3261e;
      margin-top: 6px;
    }

    /* ----- button ----- */
    .submit-row { margin-top: 18px; }
    .sign-in-btn {
      width: 100%;
      background-color: #340D1A;
      color: #ffffff;
      border: none;
      border-radius: 10px;
      padding: 16px;
      font-size: 15px;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: opacity 0.2s ease, transform 0.1s ease;
      box-shadow: 0 10px 25px rgba(52, 13, 26, 0.15);
    }
    .sign-in-btn svg { width: 16px; height: 16px; }
    .sign-in-btn:hover { opacity: 0.9; }
    .sign-in-btn:active { transform: scale(0.98); }
    .sign-in-btn[aria-busy="true"] {
      opacity: 0.7;
      pointer-events: none;
    }

    /* ----- footer ----- */
    .page-footer { margin-top: 32px; text-align: center; }
    .page-footer p { margin: 0; font-size: 13px; color: #B5A391; }

    /* ----- utils (no unused) ----- */
    .hidden { display: none !important; }
